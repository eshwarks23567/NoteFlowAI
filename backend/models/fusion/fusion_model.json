    "gesture_pose": 0.28,
    "voice_audio": 0.27,
    "text_nlp": 0.18,
    "temporal": 0.05
  },
  "config": {
    "hidden_dim": 256,
    "num_attention_heads": 4,
    "fusion_strategy": "cross_attention",
    "epochs": 20
  }
