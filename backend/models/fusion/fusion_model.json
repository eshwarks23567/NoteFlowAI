    },
    {
      "epoch": 5,
      "mse_loss": 0.0716,
      "pearson_r": 0.882,
      "bce_loss": 0.1872
    }
  ],
  "modalities": [
    "slide_visual",
    "gesture_pose",
    "voice_audio",
    "text_nlp",
    "temporal"
  ],
  "feature_dims": {
    "slide_visual": 128,
    "gesture_pose": 64,
    "voice_audio": 64,
    "text_nlp": 128,
    "temporal": 16
  },
  "modality_weights_learned": {
