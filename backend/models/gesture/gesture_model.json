{
  "architecture": {
    "spatial_stream": {
      "description": "Per-frame pose feature extraction",
      "layers": [
        {
          "type": "linear",
          "in": 67,
          "out": 128,
          "activation": "relu"
        },
        {
          "type": "batchnorm1d",
          "features": 128
        },
        {
          "type": "dropout",
          "p": 0.3
        },
        {
          "type": "linear",
          "in": 128,
          "out": 64,
          "activation": "relu"
        }
      ]
    },
    "temporal_stream": {
      "description": "Sequence of pose features \u2192 gesture classification",
      "layers": [
        {
          "type": "lstm",
          "input": 64,
          "hidden": 128,
          "layers": 2,
          "bidirectional": true
        },
        {
          "type": "attention",
          "hidden": 256
        },
        {
          "type": "linear",
          "in": 256,
          "out": 8,
          "activation": "softmax"
        }
      ]
    },
    "hand_region_cnn": {
      "description": "Optional CNN for cropped hand region classification",
      "layers": [
        {
          "type": "conv2d",
          "filters": 32,
          "kernel": 3,
          "activation": "relu"
        },
        {
          "type": "maxpool2d",
          "kernel": 2
        },
        {
          "type": "conv2d",
          "filters": 64,
          "kernel": 3,
          "activation": "relu"
        },
        {
          "type": "global_avg_pool"
        },
        {
          "type": "linear",
          "in": 64,
          "out": 8
        }
      ]
    }
  },
